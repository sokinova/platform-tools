{
  "_comment": "IAM policy template for FluentD S3 access. The bucket name 'eks-logs-312ubuntu-dev' is replaced by irsa-setup.sh with the environment-specific bucket name (e.g., eks-logs-312ubuntu-staging).",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowS3ListBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::eks-logs-312ubuntu-dev"
      ]
    },
    {
      "Sid": "AllowS3WriteObjects",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:PutObjectAcl",
        "s3:GetObject",
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::eks-logs-312ubuntu-dev/logs/*"
      ]
    }
  ]
}
